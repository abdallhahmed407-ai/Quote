{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "quote",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": ["nodejs_compat_v2"],
  "workers_dev": true,
  "browser": {
    "binding": "BROWSER",
    "remote": true
  },
  "triggers": {
    "crons": ["* * * * *"]
  }
}
